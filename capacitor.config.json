{
  "appId": "com.vmstudios.killerdarts",
  "appName": "Killer Darts",
  "webDir": "www",
  "plugins": {
    "Keyboard": {
      "resize": "none",
      "resizeOnFullScreen": true
    },
    "SplashScreen": {
      "launchShowDuration": 500,
      "launchAutoHide": true,
      "backgroundColor": "#000000",
      "androidScaleType": "CENTER_CROP",
      "launchFadeInDuration": 0,
      "launchFadeOutDuration": 200
    }
  }
}